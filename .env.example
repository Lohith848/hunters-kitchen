# Supabase Configuration
# Get these values from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL (for auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp number for receiving orders (include country code, no +)
# Example: 919876543210 for India
NEXT_PUBLIC_WHATSAPP_NUMBER=916383346991

# Admin Setup
# After creating your Supabase project:
# 1. Sign up with your admin email through the login page
# 2. Go to Supabase SQL Editor and run:
#    INSERT INTO admins (id, email) VALUES ('<your-user-id>', 'your@email.com');
# You can find your user ID in Authentication > Users
